# Puerto del servidor (por defecto 3000)
PORT=3000

# Seguridad JWT — cámbialo antes de usar en producción
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# WebAuthn / Face ID
# RP_ID: el dominio sin protocolo (localhost en dev, tu dominio en prod)
RP_ID=localhost
# ORIGIN: URL completa (con protocolo)
ORIGIN=http://localhost:3000

# API Key de AEMET (https://opendata.aemet.es)
AEMET_API_KEY=tu_api_key_aqui

# Permitir registro de más usuarios (true/false)
ALLOW_REGISTRATION=false
